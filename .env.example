# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# PostgreSQL / Supabase Connection
# Supabase shared pooler format: postgres.[PROJECT-REF]
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-[REGION].pooler.supabase.com:5432/postgres

# OR use individual fields:
DB_HOST=aws-[REGION].pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.[PROJECT-REF]
DB_PASSWORD=your_password_here

# Bot Settings
NODE_ENV=development
LOG_LEVEL=info

# Auto-delete delay in milliseconds (default: 5 minutes)
AUTO_DELETE_DELAY=300000

# Default timezone
DEFAULT_TIMEZONE=UTC
